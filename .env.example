# Example .env file – copy to .env and fill in your values.
# Never commit the real .env to source control.

# LM-Studio
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=local-model

# File tool
USER_DATA_DIR=user_data

# ── Tier 1 (VS Code / Cline) ─────────────────────────────────────────────────
# Path or name of the Cline CLI executable
CLINE_EXECUTABLE=cline
# Seconds to wait for Cline to respond (default: 120)
CLINE_TIMEOUT_SECONDS=120
# Pass prompt via stdin (true) or via a temp file (false)
CLINE_STDIN_MODE=true

# ── Tier 2 (Claude API) ───────────────────────────────────────────────────────
# Anthropic API key – required for Tier-2 escalation
ANTHROPIC_API_KEY=
# Claude model to use (default: claude-3-5-haiku-20241022)
CLAUDE_MODEL=claude-3-5-haiku-20241022
# Max tokens in Claude's response (default: 4096)
CLAUDE_MAX_TOKENS=4096
# API call timeout in seconds (default: 60)
CLAUDE_TIMEOUT_SECONDS=60

# ── Tier 3 (Playwright browser) ──────────────────────────────────────────────
# AI web UI to open (default: https://claude.ai/new)
TIER3_TARGET_URL=https://claude.ai/new
# Run browser headless (default: true — set to false to see the browser)
TIER3_HEADLESS=true
# Path to a persistent Chrome profile dir so the user stays logged in
CHROME_PROFILE_DIR=
# Browser navigation timeout in ms (default: 60000)
TIER3_BROWSER_TIMEOUT_MS=60000
# Time to wait for the AI to respond in ms (default: 120000)
TIER3_RESPONSE_TIMEOUT_MS=120000

# ── SMTP (email_tool) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=

